<div class="bg-light shadow-sm p-5 rounded">
  <h1 class="display-6 fw-bold mb-4">Forgot Your Password?</h1>

  <%= form_with url: password_reset_path do |form| %>
    <div class="mb-4">
      <%= form.label :email, class: "form-label fw-semibold" %>
      <%= form.text_field :email, class: "form-control form-control-lg", placeholder: "e.g., steve123@gmail.com" %>
    </div>

    <%= form.submit "Send Reset Instructions", class: "btn btn-dark btn-lg px-5" %>
  <% end %>
</div>
