<div class="bg-light shadow-sm p-5 rounded text-center mt-5 mb-5">
  <h1 class="display-4 mb-4 fw-bold text-dark">Welcome to Scheduled Tweets</h1>
  <p class="lead text-muted">
    Schedule your tweets effortlessly and let our app take care of posting them at the right time.
  </p>

  <div class="mt-4">
    <% if Current.user %>
      <% if Current.user.twitter_account.none? %>
        <%= button_to "Connect to X.com", "/auth/twitter", data: { turbo: "false" }, method: :post, class: "btn btn-dark btn-lg" %>
      <% else %>
        <div class="alert alert-success">
          Connected to X.com as <strong><%= Current.user.twitter_account.first.username %></strong>.
        </div>
        <%= link_to "View Scheduled Tweets", tweets_path, class: "btn btn-dark btn-lg me-3" %>
        <%= link_to "Schedule a New Tweet", new_tweet_path, class: "btn btn-outline-dark btn-lg" %>
      <% end %>
    <% else %>
      <p class="mt-3">
        Please <%= link_to "log in", sign_in_path, class: "text-decoration-underline" %> to access your account.
      </p>
    <% end %>
  </div>
</div>