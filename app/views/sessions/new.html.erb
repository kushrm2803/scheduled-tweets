<div class="bg-light shadow-sm p-4 rounded">
  <h1 class="display-6 fw-bold mb-4">Sign In</h1>

  <%= form_with url: sign_in_path do |form| %>
    <div class="mb-2">
      <%= form.label :email, class: "form-label fw-semibold" %>
      <%= form.text_field :email, class: "form-control form-control-lg", placeholder: "steve123@gmail.com" %>
    </div>

    <div class="mb-2">
      <%= form.label :password, class: "form-label fw-semibold" %>
      <%= form.password_field :password, class: "form-control form-control-lg", placeholder: "Enter password" %>
      <%= link_to "Forgot your password?", password_reset_path, class: "d-block mt-2 text-primary" %>
    </div>

    <%= form.submit "Sign In", class: "btn btn-dark btn-lg px-5 mt-4" %>
  <% end %>
</div>
